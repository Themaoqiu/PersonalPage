---
interface Props {
  title: string
  arxivUrl: string
  hjfyUrl: string
  summary: string
}

const { title, arxivUrl, hjfyUrl, summary } = Astro.props as Props
---

<article class='group mb-4 rounded-xl border border-border bg-card p-4 transition-all hover:border-foreground/25 hover:shadow-md sm:p-5'>
  <h3 class='m-0 text-lg font-semibold leading-snug text-foreground transition-colors group-hover:text-primary sm:text-xl'>
    {title}
  </h3>

  <div class='mt-3 flex flex-wrap gap-2'>
    <a
      class='inline-flex items-center gap-1.5 rounded-full border border-slate-400/40 bg-[#BECEF1] px-3 py-1.5 text-xs font-semibold text-slate-900 shadow-sm transition-all hover:brightness-95 hover:shadow focus-visible:ring-2 focus-visible:ring-slate-500 ring-offset-background ring-offset-2 dark:border-slate-300/30 dark:bg-[#5C6F96] dark:text-slate-100 dark:hover:brightness-110'
      href={arxivUrl}
      target='_blank'
      rel='noopener noreferrer'
    >
      ArXiv
    </a>
    <a
      class='inline-flex items-center gap-1.5 rounded-full border border-slate-400/40 bg-[#BEBEE7] px-3 py-1.5 text-xs font-semibold text-slate-900 shadow-sm transition-all hover:brightness-95 hover:shadow focus-visible:ring-2 focus-visible:ring-slate-500 ring-offset-background ring-offset-2 dark:border-slate-300/30 dark:bg-[#646491] dark:text-slate-100 dark:hover:brightness-110'
      href={hjfyUrl}
      target='_blank'
      rel='noopener noreferrer'
    >
      幻觉翻译
    </a>
  </div>

  <p class='mt-4 whitespace-pre-wrap text-sm leading-relaxed text-muted-foreground dark:text-slate-300'>{summary}</p>
</article>
