---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { getRelativeLocaleUrl } from 'astro:i18n'

// Plugin styles
import 'katex/dist/katex.min.css'

import { Comment, MediumZoom } from '@/components/advanced'
import { ArticleBottom, Copyright, Hero, TOC } from '@/components/pages'
import PageLayout from '@/layouts/ContentLayout.astro'
import { integ } from '@/site-config'

interface Props {
  post: CollectionEntry<'blog'> | CollectionEntry<'blogEn'>
  posts: CollectionEntry<'blog'>[] | CollectionEntry<'blogEn'>[]
  headings: MarkdownHeading[]
  remarkPluginFrontmatter: Record<string, unknown>
}

const {
  post: { id, data },
  posts,
  headings,
  remarkPluginFrontmatter
} = Astro.props

const {
  description,
  heroImage,
  publishDate,
  title,
  updatedDate,
  draft: isDraft,
  comment: enableComment
} = data

const socialImage = heroImage
  ? typeof heroImage.src === 'string'
    ? heroImage.src
    : heroImage.src.src
  : '/images/social-card.png'
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString()
const primaryColor = data.heroImage?.color ?? 'hsl(var(--primary) / var(--tw-text-opacity))'
const isPaperPost = id.startsWith('papers-') || data.tags.includes('paperreading') || data.tags.includes('papers')
const showToc = headings.length > 0

function getLocalizedUrl(locale: string | undefined, target: string) {
  let url = getRelativeLocaleUrl(locale || 'zh', target)
  if (url !== '/' && url.endsWith('/')) {
    url = url.slice(0, -1)
  }
  return url
}

const backPath = isPaperPost
  ? getLocalizedUrl(Astro.currentLocale, '/blog/papers')
  : getLocalizedUrl(Astro.currentLocale, '/blog')
---

<PageLayout
  meta={{ articleDate, description, ogImage: socialImage, title }}
  highlightColor={primaryColor}
  back={backPath}
>
  {showToc && <TOC {headings} slot='sidebar' />}

  <Hero {data} {remarkPluginFrontmatter} slot='header' />

  <slot />

  <Fragment slot='bottom'>
    {/* Copyright */}
    <Copyright {data} />
    {/* Article recommend */}
    <ArticleBottom collections={posts} {id} class='mt-3 sm:mt-6' />
    {/* Comment */}
    {!isDraft && enableComment && !isPaperPost && <Comment class='mt-3 sm:mt-6' />}
  </Fragment>

  <slot name='bottom-sidebar' slot='bottom-sidebar' />
</PageLayout>

{integ.mediumZoom.enable && <MediumZoom />}
